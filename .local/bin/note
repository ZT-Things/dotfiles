#!/bin/bash

VAULT="$HOME/obsidian-vault"
EDITOR="nvim"
SHORTCUT_FILE="$VAULT/shortcut.conf"
TMUX_SESSION="vault"

open_file() {
    mkdir -p "$(dirname "$1")"
    "$EDITOR" "$1"
}

create_daily_if_missing() {
    FILE="$1"
    DATE_STRING="$2"

    if [ ! -f "$FILE" ]; then
        cat <<EOF > "$FILE"
# $DATE_STRING

## Today
-

## Working On
-

## Notes
-

## End of Day
-
EOF
    fi
}

open_daily_by_date() {
    TARGET_DATE="$1"

    if ! DATE_PARSED=$(date -d "$TARGET_DATE" +%F 2>/dev/null); then
        echo "Invalid date."
        exit 1
    fi

    YEAR=$(date -d "$DATE_PARSED" +%Y)
    MONTH_NAME=$(date -d "$DATE_PARSED" +%B)

    DIR="$VAULT/00-daily/$YEAR/$MONTH_NAME"
    FILE="$DIR/$DATE_PARSED.md"

    mkdir -p "$DIR"
    create_daily_if_missing "$FILE" "$DATE_PARSED"
    "$EDITOR" "$FILE"
}

# -----------------------------
# Shortcut resolver
# -----------------------------

resolve_shortcut() {
    KEY="$1"

    if [ ! -f "$SHORTCUT_FILE" ]; then
        return 1
    fi

    grep -E "^${KEY}=" "$SHORTCUT_FILE" | head -n1 | cut -d'=' -f2-
}

# -----------------------------
# Tmux launcher
# -----------------------------

launch_tmux() {
    TARGET_DIR="$1"
    SESSION_NAME="$2"

    if [ ! -d "$TARGET_DIR" ]; then
        mkdir -p "$TARGET_DIR"
    fi

    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        tmux attach-session -t "$SESSION_NAME"
    else
        tmux new-session -s "$SESSION_NAME" -c "$TARGET_DIR"
    fi
}

# -----------------------------
# note tmux
# -----------------------------

if [ "$1" == "tmux" ]; then
    TARGET="$VAULT"
    SESSION_NAME="vault"

    if [[ "$2" == -* ]]; then
        KEY="${2#-}"
        SHORT=$(resolve_shortcut "$KEY")

        if [ -n "$SHORT" ]; then
            TARGET="$VAULT/$SHORT"
            SESSION_NAME="vault-$KEY"
        else
            echo "Shortcut '$KEY' not found."
            exit 1
        fi
    fi

    launch_tmux "$TARGET" "$SESSION_NAME"
    exit 0
fi

# -----------------------------
# note -shortcut
# -----------------------------

if [[ "$1" == -* ]]; then
    KEY="${1#-}"
    TARGET=$(resolve_shortcut "$KEY")

    if [ -n "$TARGET" ]; then
        open_file "$VAULT/$TARGET"
        exit 0
    else
        echo "Shortcut '$KEY' not found."
        exit 1
    fi
fi

# -----------------------------
# Default behavior
# -----------------------------

if [ $# -eq 0 ]; then
    open_file "$VAULT/Random.md"
    exit 0
fi

# -----------------------------
# Main command router
# -----------------------------

case "$1" in
    n)
        [ -z "$2" ] && { echo "Usage: note n <name>"; exit 1; }
        open_file "$VAULT/01-notes/$2.md"
        ;;
    p)
        [ -z "$2" ] && { echo "Usage: note p <name>"; exit 1; }
        open_file "$VAULT/02-projects/$2.md"
        ;;
    d)
        open_daily_by_date "today"
        ;;
    dt)
        open_daily_by_date "tomorrow"
        ;;
    dm)
        [ -z "$2" ] && { echo "Usage: note dm <day-of-month>"; exit 1; }

        YEAR=$(date +%Y)
        MONTH=$(date +%m)
        TARGET_DATE="$YEAR-$MONTH-$2"

        open_daily_by_date "$TARGET_DATE"
        ;;
    sync)
        cd "$VAULT" || { echo "Vault not found."; exit 1; }

        if [ ! -d ".git" ]; then
            echo "Not a git repository."
            exit 1
        fi

        git add -A

        if git diff --cached --quiet; then
            echo "No changes to commit."
            exit 0
        fi

        TIMESTAMP=$(date +"%Y-%m-%d %H:%M:%S")
        git commit -m "vault backup: $TIMESTAMP"
        git push origin main

        echo "Vault synced."
        ;;
    *)
        echo "Unknown command."
        echo "Usage:"
        echo "  note                → Random.md"
        echo "  note -<shortcut>    → open shortcut"
        echo "  note tmux           → tmux in vault"
        echo "  note tmux -<key>    → tmux in shortcut dir"
        echo "  note n <name>       → note file"
        echo "  note p <name>       → project file"
        echo "  note d              → today"
        echo "  note dt             → tomorrow"
        echo "  note dm <day>       → specific day"
        echo "  note sync           → git sync"
        exit 1
        ;;
esac
